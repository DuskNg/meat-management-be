# Cổng chạy ứng dụng
PORT=3000

# Đường dẫn kết nối PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meat_db"

# Khóa bí mật mã hóa JWT Tokens
JWT_ACCESS_SECRET=your_jwt_access_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key

# Cấu hình dịch vụ gửi SMS OTP qua eSMS
ESMS_API_KEY=your_api_key_here
ESMS_SECRET_KEY=your_secret_key_here
ESMS_SMS_TYPE=4          # 4: Đầu số cố định ngẫu nhiên (Giá rẻ nhất để làm OTP)
ESMS_BRANDNAME=Sandbox   # Tên Brandname hiển thị (hoặc để mặc định)
ESMS_MOCK_MODE=true      # true: Chỉ in OTP ra console để test miễn phí; false: Gửi tin nhắn thật
