// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL") // --- VẤN ĐỀ 1: Thêm dòng connection string theo yêu cầu (đã comment out để tương thích với Prisma v7) ---
}

model User {
  id        String   @id @default(uuid())
  name      String   // Tên hiển thị của chủ buôn
  phone     String   @unique // Số điện thoại dùng làm tài khoản đăng nhập (duy nhất)
  createdAt DateTime @default(now()) // Thời gian tạo tài khoản
  updatedAt DateTime @updatedAt // Thời gian tự động cập nhật mỗi khi thay đổi thông tin

  // Các quan hệ liên kết
  customers    Customer[]    // Một chủ buôn quản lý nhiều khách hàng
  products     Product[]     // Một chủ buôn quản lý danh mục sản phẩm/thịt riêng
  transactions Transaction[] // Các giao dịch được ghi nhận bởi chủ buôn này
  suppliers    Supplier[]    // Một chủ buôn quản lý nhiều nhà cung cấp tiền hàng
  employees    Employee[]    // Một chủ buôn quản lý nhiều nhân viên sạp hàng

  @@map("users") // Đặt tên bảng trong PostgreSQL là "users"
}

model OTP {
  id        String    @id @default(uuid())
  phone     String    // Số điện thoại nhận mã xác thực OTP
  code      String    // Mã xác thực OTP (thường là 4 hoặc 6 chữ số)
  expiresAt DateTime  // Thời điểm mã OTP hết hiệu lực (5 phút từ khi tạo)
  usedAt    DateTime? // Thời điểm mã OTP được kích hoạt thành công
  createdAt DateTime  @default(now()) // Thời điểm gửi mã OTP

  @@index([phone]) // Đánh chỉ mục số điện thoại để tối ưu tốc độ tìm kiếm mã OTP gần nhất
  @@map("otps") // Đặt tên bảng trong PostgreSQL là "otps"
}

model Customer {
  id        String   @id @default(uuid())
  userId    String   // ID của chủ buôn quản lý khách hàng này
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   // Tên khách hàng (ví dụ: Chị Lan bán phở, Anh Hùng nhà hàng)
  phone     String?  // Số điện thoại liên hệ (có thể để trống)
  address   String?  // Địa chỉ giao hàng/cửa hàng của khách
  note      String?  // Ghi chú chi tiết (ví dụ: chỉ lấy sườn non buổi sáng, thanh toán cuối tuần)
  
  // --- VẤN ĐỀ 2: Thêm isActive để phục vụ Soft Delete ---
  isActive    Boolean  @default(true) // Trạng thái hoạt động. Chức năng "xóa khách hàng" ở app sẽ set isActive = false (soft delete), KHÔNG gọi DELETE thật trên Customer để bảo toàn lịch sử nợ.
  isBadDebt   Boolean  @default(false) // Trạng thái nợ xấu (khoanh vùng lưu trữ)
  manualDebt  Decimal  @default(0) @db.Decimal(12, 2) // Số tiền nợ ban đầu được nhập thủ công (dành cho khách nợ xấu không có lịch sử giao dịch)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Các quan hệ liên kết
  transactions Transaction[] // Một khách hàng có nhiều giao dịch mua hàng theo thời gian
  
  // --- VẤN ĐỀ 3: Di chuyển quan hệ Payment từ Transaction sang Customer ---
  payments     Payment[]     // Danh sách các đợt thanh toán nợ của khách hàng này
  customPrices CustomerProductPrice[] // Danh sách giá bán riêng của khách hàng này cho từng loại thịt

  @@index([userId]) // Tối ưu hóa truy vấn tìm kiếm danh sách khách hàng của từng chủ buôn
  @@map("customers") // Đặt tên bảng trong PostgreSQL là "customers"
}

model Product {
  id           String            @id @default(uuid())
  userId       String            // ID của chủ buôn sở hữu sản phẩm này
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String            // Tên sản phẩm thịt (ví dụ: Ba chỉ, Sườn non, Móng giò)
  defaultPrice Decimal           @db.Decimal(12, 2) // Giá bán mặc định trên một đơn vị (VND)
  unit         String            @default("kg") // Đơn vị tính (mặc định là kg, có thể là "bộ", "cái")
  isActive     Boolean           @default(true) // Trạng thái kích hoạt (cho phép ẩn khi không còn bán nữa)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Các quan hệ liên kết
  transactionItems TransactionItem[] // Danh sách các chi tiết dòng đơn hàng sử dụng sản phẩm này
  customPrices     CustomerProductPrice[] // Danh sách giá bán riêng của sản phẩm này cho từng khách hàng

  @@index([userId]) // Tối ưu hóa truy vấn danh mục sản phẩm theo chủ buôn
  @@map("products") // Đặt tên bảng trong PostgreSQL là "products"
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String   // ID của chủ buôn tạo giao dịch
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId  String   // ID của khách hàng mua sản phẩm
  
  // --- VẤN ĐỀ 2: Đổi onDelete: Cascade sang Restrict để chặn xóa cứng Customer khi còn đơn nợ ---
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Restrict) 
  
  date        DateTime @default(now()) // Ngày thực hiện giao dịch mua bán
  note        String?  // Ghi chú riêng cho đơn hàng này
  totalAmount Decimal  @db.Decimal(12, 2) // Tổng giá trị đơn hàng sau khi tính tổng các dòng
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Các quan hệ liên kết
  items    TransactionItem[] // Danh sách chi tiết các loại thịt được bán trong giao dịch này
  
  // --- VẤN ĐỀ 3: Đã bỏ quan hệ trực tiếp "payments" tại đây ---

  @@index([userId])
  @@index([customerId])
  @@index([date]) // Tối ưu hóa lọc lịch sử giao dịch theo ngày
  @@map("transactions") // Đặt tên bảng trong PostgreSQL là "transactions"
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String      // ID của giao dịch chứa dòng sản phẩm này
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String      // ID của sản phẩm thịt
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict) // Không cho phép xoá cứng Product nếu đã có giao dịch sử dụng để bảo toàn dữ liệu lịch sử nợ
  quantity      Decimal     @db.Decimal(10, 3) // Khối lượng hoặc số lượng bán (ví dụ: 1.255 kg)
  price         Decimal     @db.Decimal(12, 2) // Giá bán thực tế lúc đó (có thể thương lượng khác giá mặc định)
  amount        Decimal     @db.Decimal(12, 2) // Thành tiền cho dòng này (= quantity * price)

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items") // Đặt tên bảng trong PostgreSQL là "transaction_items"
}

model Payment {
  id            String      @id @default(uuid())
  
  // --- VẤN ĐỀ 3: Chuyển quan hệ thanh toán từ liên kết Transaction sang Customer ---
  customerId    String      // ID của khách hàng thanh toán tiền
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  amount        Decimal     @db.Decimal(12, 2) // Số tiền trả trong đợt này (VND)
  paidAt        DateTime    @default(now()) // Thời điểm thanh toán tiền
  note          String?     // Ghi chú thanh toán (ví dụ: trả tiền mặt tại sạp, chuyển khoản Vietcombank)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // --- VẤN ĐỀ 3: Ghi chú cách tính công nợ ---
  // Công nợ của 1 khách = tổng totalAmount của tất cả Transaction của khách trừ tổng amount của tất cả Payment của khách, KHÔNG phân bổ theo từng đơn cụ thể.

  @@index([customerId])
  @@map("payments") // Đặt tên bảng trong PostgreSQL là "payments"
}

model CustomerProductPrice {
  id          String   @id @default(uuid())
  customerId  String   // ID của khách hàng
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId   String   // ID của sản phẩm thịt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Decimal  @db.Decimal(12, 2) // Giá bán thực tế được cập nhật gần nhất cho khách hàng này
  createdAt   DateTime @default(now()) // Thời điểm tạo bản ghi
  updatedAt   DateTime @updatedAt // Thời điểm cập nhật giá lần gần nhất

  @@unique([customerId, productId]) // Mỗi khách hàng chỉ có duy nhất một giá bán riêng cho mỗi sản phẩm
  @@index([customerId])
  @@index([productId])
  @@map("customer_product_prices") // Tên bảng trong PostgreSQL
}

model Supplier {
  id        String   @id @default(uuid())
  userId    String   // ID của chủ buôn quản lý nhà cung cấp này
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   // Tên nhà cung cấp thịt (ví dụ: Lò mổ Hùng Vương, Cơ sở sỉ Anh Ba)
  phone     String?  // Số điện thoại liên hệ (có thể để trống)
  address   String?  // Địa chỉ của nhà cung cấp
  note      String?  // Ghi chú thêm
  isActive  Boolean  @default(true) // Trạng thái hoạt động (cho phép xóa mềm)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions SupplierTransaction[] // Các giao dịch nhập hàng nợ phát sinh
  payments     SupplierPayment[]     // Các giao dịch thanh toán trả nợ

  @@index([userId])
  @@map("suppliers")
}

model SupplierTransaction {
  id          String   @id @default(uuid())
  supplierId  String   // ID của nhà cung cấp
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  date        DateTime @default(now()) // Ngày nhập hàng / ghi nợ
  totalAmount Decimal  @db.Decimal(12, 2) // Số tiền hàng nhập (nợ phát sinh)
  note        String?  // Ghi chú chi tiết (ví dụ: nhập 200kg thịt ba chỉ)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
  @@map("supplier_transactions")
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String   // ID của nhà cung cấp được trả nợ
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2) // Số tiền trả nợ (VND)
  paidAt      DateTime @default(now()) // Ngày thanh toán tiền
  note        String?  // Ghi chú thanh toán (ví dụ: chuyển khoản Vietcombank)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
  @@map("supplier_payments")
}

model Employee {
  id          String   @id @default(uuid())
  userId      String   // ID của chủ buôn quản lý nhân viên này
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // Tên nhân viên
  phone       String?  // Số điện thoại
  address     String?  // Địa chỉ
  role        String?  // Vị trí công việc (ví dụ: Giao hàng, Lọc thịt, Bán sạp)
  baseSalary  Decimal  @db.Decimal(12, 2) // Lương cơ bản tháng (VND)
  isActive    Boolean  @default(true) // Trạng thái hoạt động (cho phép xóa mềm)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances Attendance[] // Danh sách chấm công của nhân viên
  advances    SalaryAdvance[] // Các đợt tạm ứng lương
  payments    SalaryPayment[] // Bảng lương tháng chốt thực nhận

  @@index([userId])
  @@map("employees")
}

model Attendance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime // Ngày chấm công (chỉ lấy phần ngày, bỏ giờ)
  status      String   // PRESENT (Đi làm), ABSENT (Nghỉ không phép)
  shift       String   @default("FULL") // FULL (Cả ngày = 1 công), HALF (Nửa ngày = 0.5 công)
  note        String?  // Ghi chú chấm công
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, date]) // Mỗi nhân viên chỉ chấm công 1 lần trong ngày
  @@index([employeeId])
  @@map("employee_attendances")
}

model SalaryAdvance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(12, 2) // Số tiền tạm ứng (VND)
  date        DateTime @default(now()) // Ngày ứng lương
  note        String?  // Lý do ứng lương
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
  @@map("employee_salary_advances")
}

model SalaryPayment {
  id               String    @id @default(uuid())
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  monthKey         String    // Tháng tính lương (ví dụ: "07/2026")
  baseSalary       Decimal   @db.Decimal(12, 2) // Mức lương gốc áp dụng
  workingDays      Decimal   @db.Decimal(5, 2)  // Tổng ngày công đi làm thực tế trong tháng
  advancesDeducted Decimal   @db.Decimal(12, 2) // Tiền tạm ứng khấu trừ
  bonus            Decimal   @db.Decimal(12, 2) @default(0) // Tiền thưởng thêm
  deductions       Decimal   @db.Decimal(12, 2) @default(0) // Khoản phạt/trừ đi
  finalAmount      Decimal   @db.Decimal(12, 2) // Thực lĩnh
  status           String    @default("PAID") // PAID (Đã chi trả), PENDING (Chưa thanh toán)
  paidAt           DateTime? // Ngày chi trả thực tế
  note             String?   // Ghi chú
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([employeeId, monthKey]) // Mỗi nhân viên chỉ chốt lương 1 lần duy nhất trong tháng
  @@index([employeeId])
  @@map("employee_salary_payments")
}
